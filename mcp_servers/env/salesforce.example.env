# Salesforce OAuth Client-Credentials
# Requires a Connected App with "Client Credentials" flow enabled.
# SALESFORCE_DOMAIN supports full My Domain URLs (e.g. yourorg.my.salesforce.com)
# or simple prefixes (e.g. login, test).
SALESFORCE_DOMAIN=yourorg.my.salesforce.com
SALESFORCE_CLIENT_ID=your_connected_app_client_id
SALESFORCE_CLIENT_SECRET=your_connected_app_client_secret
