# ===========================================================================
# ESS-MCP – Deployment Environment Variables
# ===========================================================================
# Copy this file to .env and fill in the values for the services you are
# deploying. Only the variables for your selected servers are required.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your credentials
#   ./deploy.sh --env-file .env --servers workday,jira
# ===========================================================================

# ── Workday ────────────────────────────────────────────────────────────────
# AAD_APP_CLIENT_ID=
# AAD_APP_TENANT_ID=
# OPENAPI_SERVER_DOMAIN=
# WORKDAY_TOKEN_URL=
# WORKDAY_WORKERS_API_URL=
# WORKDAY_CLIENT_CREDENTIALS=
# WORKDAY_CLIENT_SECRET=
# WORKDAY_REFRESH_TOKEN=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=
# GRAPH_TENANT_ID=

# ── ServiceNow ─────────────────────────────────────────────────────────────
# SERVICENOW_INSTANCE_URL=https://yourinstance.service-now.com
# SERVICENOW_CLIENT_ID=
# SERVICENOW_CLIENT_SECRET=

# ── Salesforce ─────────────────────────────────────────────────────────────
# SALESFORCE_DOMAIN=yourorg.my.salesforce.com
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=

# ── Jira ───────────────────────────────────────────────────────────────────
# JIRA_BASE_URL=https://yourorg.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=
