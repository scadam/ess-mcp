# ===========================================================================
# ESS-MCP – Deployment Environment Variables
# ===========================================================================
# Copy this file to .env and fill in the values for the services you are
# deploying. Only the variables for your selected servers are required.
#
# Authentication: Each MCP server uses OAuth 2.0 bearer token passthrough.
# The bearer token is provided by the MCP client in the Authorization header
# and forwarded directly to the target SaaS API. No additional credentials
# (client secrets, API keys, etc.) are needed here.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your service URLs
#   ./deploy.sh --env-file .env --servers workday,jira
# ===========================================================================

# ── Workday ────────────────────────────────────────────────────────────────
# WORKDAY_WORKERS_API_URL=https://your-workday.com/api/v1/workers

# ── ServiceNow ─────────────────────────────────────────────────────────────
# SERVICENOW_INSTANCE_URL=https://yourinstance.service-now.com

# ── Salesforce ─────────────────────────────────────────────────────────────
# SALESFORCE_DOMAIN=yourorg.my.salesforce.com

# ── Jira ───────────────────────────────────────────────────────────────────
# JIRA_BASE_URL=https://yourorg.atlassian.net
# JIRA_PROJECT_KEY=
